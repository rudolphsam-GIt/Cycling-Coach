# ============================================================
# CYCLING COACH — API KEYS SETUP
# ============================================================
# Copy this file to a new file called ".env" (no .example)
# and fill in your values below.
# ============================================================

# --- STRAVA ---
# 1. Go to https://www.strava.com/settings/api
# 2. Create an app. Set "Authorization Callback Domain" to: localhost
# 3. Copy the Client ID and Client Secret here
STRAVA_CLIENT_ID=paste_your_client_id_here
STRAVA_CLIENT_SECRET=paste_your_client_secret_here

# --- GARMIN ---
# Your regular Garmin Connect login credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_password

# --- CLAUDE AI ---
# 1. Go to https://console.anthropic.com/
# 2. Click "API Keys" and create a new key
# 3. Paste it below
ANTHROPIC_API_KEY=paste_your_key_here
